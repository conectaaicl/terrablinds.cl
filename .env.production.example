# ============================================
# TerraBlinds - Production Environment (VPS)
# ============================================
# Copy to .env on the VPS and fill in real values.
# NEVER commit the real .env to git.
# Generate JWT_SECRET: openssl rand -hex 32

# ---------- Database ----------
DB_USER=terrablinds
DB_PASSWORD=CHANGE_ME_strong_random_password
DB_NAME=terrablinds_db

# ---------- Authentication ----------
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# ---------- CORS / URLs ----------
CORS_ORIGINS=https://terrablinds.cl,https://www.terrablinds.cl
BASE_URL=https://terrablinds.cl
FRONTEND_URL=https://terrablinds.cl
SITE_URL=https://terrablinds.cl

# ---------- Frontend ----------
# Must match the public domain — used at Vite build time (baked into bundle)
VITE_API_URL=https://terrablinds.cl

# ---------- Payment - Flow.cl ----------
FLOW_API_KEY=CHANGE_ME
FLOW_SECRET_KEY=CHANGE_ME
FLOW_API_URL=https://www.flow.cl/api

# ---------- Email - Resend ----------
RESEND_API_KEY=CHANGE_ME
RESEND_FROM_EMAIL=TerraBlinds <noreply@terrablinds.cl>
